# OpenClaw Gateway — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── LLM Provider ──────────────────────────────────────────────────────────────
VLLM_BASE_URL=https://your-endpoint.example.com/v1
VLLM_API_KEY=your_api_key_here
VLLM_MODEL_ID=your-model-id

# ── WhatsApp ───────────────────────────────────────────────────────────────────
# Target phone number to send test messages to (no leading +)
WHATSAPP_TARGET=91XXXXXXXXXX
# E.164 format (with leading +) used by openclaw agent --to
WHATSAPP_TARGET_E164=+91XXXXXXXXXX
